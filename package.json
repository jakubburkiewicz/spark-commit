{
  "name": "spark-commit",
  "displayName": "Spark Commit",
  "description": "AI-powered git commit message generator. Currently supports Claude CLI.",
  "version": "0.0.1",
  "publisher": "JakubBurkiewicz",
  "engines": {
    "vscode": "^1.85.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jakubburkiewicz/spark-commit.git"
  },
  "license": "MIT",
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "spark-commit.generate",
        "title": "Spark Commit: Generate Commit Message",
        "icon": "$(sparkle)"
      }
    ]
  },
  "scripts": {
    "compile": "tsc",
    "watch": "tsc --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^6.0.3"
  }
}
